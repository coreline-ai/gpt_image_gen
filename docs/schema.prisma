generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id        String   @id @default(uuid())
  name      String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     ProjectItem[]
}

model ProjectItem {
  id        String   @id @default(uuid())
  projectId String
  prompt    String
  status    String
  imageUrl  String?
  project   Project  @relation(fields: [projectId], references: [id])
}

model ProjectLog {
  id        String   @id @default(uuid())
  projectId String
  step      String
  message   String
  createdAt DateTime @default(now())
}
